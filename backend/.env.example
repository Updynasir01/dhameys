# Copy to backend/.env or repo-root .env (both are loaded; backend wins for overlapping keys)
MONGODB_URI=mongodb://localhost:27017/dhameys

# Required for login / JWT (use long random strings in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

FRONTEND_URL=http://localhost:3000

# --- Payments (Stripe) ---
# Set PAYMENT_TEST_MODE=true to disable real Stripe calls and allow "test payments" in the UI.
# Leave unset (or false) when STRIPE_SECRET_KEY is configured.
PAYMENT_TEST_MODE=true

# Stripe keys (get these from your Stripe dashboard; NEVER commit real secrets)
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for POST /api/webhooks/stripe
# STRIPE_WEBHOOK_SECRET=whsec_...

# Flight inventory provider (default: mongo)
# Set to "mystifly" after Mystifly credentials are configured.
# FLIGHT_PROVIDER=mystifly

# --- Mystifly (optional; enable by setting FLIGHT_PROVIDER=mystifly and MYSTIFLY_BASE_URL) ---
# Base URL for Mystifly API gateway (REST/SOAP wrapper) provided by Mystifly
# MYSTIFLY_BASE_URL=
# One of these credential sets (depends on Mystifly product):
# MYSTIFLY_API_KEY=
# MYSTIFLY_CLIENT_ID=
# MYSTIFLY_CLIENT_SECRET=
# Optional: override default paths in the adapter (depends on Mystifly docs)
# MYSTIFLY_SEARCH_PATH=/flights/search
# MYSTIFLY_FARE_RULES_PATH=/flights/fare-rules
# MYSTIFLY_BOOKING_PATH=/bookings/create
# MYSTIFLY_TIMEOUT_MS=20000

# Set true to turn off email verification (no verify email queued; pending users can log in). Set false for production-style verification.
# SKIP_EMAIL_VERIFICATION=true

# --- SMTP (optional; for Gmail use an App Password, not your account password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-or-smtp-password
SMTP_FROM_NAME=Dhameys Airlines
SMTP_FROM_EMAIL=your-email@gmail.com

# SENDGRID_API_KEY=
# SENDGRID_FROM_NAME=Dhameys Airlines
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com
